										{
											"type": "bold"
										}
									],
									"text": "Horizontal Scaling"
								},
								{
									"type": "hardBreak",
									"attrs": {
										"dir": "auto"
									}
								},
								{
									"type": "text",
									"text": "“Run multiple servers instead of relying on one.”"
								}
							]
						},
						{
							"type": "heading",
							"attrs": {
								"dir": "auto",
								"level": 3
